{
  "name": "blog",
  "description": "re-taro's blog",
  "version": "1.0.0",
  "author": {
    "name": "Rintaro Itokawa",
    "email": "me@re-taro.dev",
    "url": "https://re-taro.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-taro/blog.re-taro.dev",
    "directory": "app"
  },
  "scripts": {
    "start": "next start",
    "build": "next build",
    "dev": "next dev --turbo",
    "lint": "run-s -c lint:*",
    "lint:eslint": "eslint . --ext .cjs,.mjs,.ts,.tsx,.json",
    "lint:prettier": "prettier --check **/*.{cjs,mjs,tsx,json}",
    "fmt": "run-s -c fmt:*",
    "fmt:eslint": "pnpm lint:eslint --fix",
    "fmt:prettier": "prettier --write **/*.{cjs,mjs,tsx,json}"
  },
  "dependencies": {
    "next": "13.4.9",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@re-taro/eslint-config": "1.9.16",
    "@types/node": "20.4.1",
    "@types/react": "18.2.14",
    "@types/react-dom": "18.2.6",
    "eslint": "8.44.0",
    "eslint-config-prettier": "8.8.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.0.0",
    "tsconfig": "workspace:*"
  }
}
