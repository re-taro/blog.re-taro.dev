{
  "name": "remark-heading-id",
  "description": "remark plugin to add id to heading",
  "version": "1.0.0",
  "author": {
    "name": "Rintaro Itokawa",
    "email": "me@re-taro.dev",
    "url": "https://re-taro.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-taro/blog.re-taro.dev",
    "directory": "packages/remark-heading-id"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "analyze": "tsc -p tsconfig.packelyze.json && packelyze analyze-dts",
    "build": "pnpm run analyze && rollup -c",
    "lint": "run-s -c lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . -c",
    "lint:ts": "tsc -p . --noEmit",
    "fmt": "run-s -c fmt:*",
    "fmt:eslint": "pnpm lint:eslint --fix",
    "fmt:prettier": "prettier . -w"
  },
  "dependencies": {
    "github-slugger": "2.0.0",
    "mdast-util-to-string": "4.0.0",
    "mdast-utils": "workspace:*",
    "unist-util-visit": "4.1.2"
  },
  "devDependencies": {
    "@re-taro/eslint-config": "2.1.1",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "11.1.5",
    "@types/mdast": "3.0.14",
    "eslint": "8.52.0",
    "npm-run-all": "4.1.5",
    "packelyze": "0.2.0",
    "prettier": "3.0.3",
    "rollup": "4.3.0",
    "tsconfig": "workspace:*",
    "unified": "10.1.2"
  }
}
