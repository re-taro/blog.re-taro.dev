{
  "name": "tsconfig",
  "description": "custom tsconfig",
  "version": "1.0.0",
  "author": {
    "name": "Rintaro Itokawa",
    "email": "me@re-taro.dev",
    "url": "https://re-taro.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-taro/blog.re-taro.dev",
    "directory": "packages/tsconfig"
  },
  "type": "module",
  "scripts": {
    "lint": "run-s -c lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . -c",
    "fmt": "run-s -c fmt:*",
    "fmt:eslint": "pnpm lint:eslint --fix",
    "fmt:prettier": "prettier . -w"
  },
  "devDependencies": {
    "@re-taro/eslint-config": "2.1.1",
    "@tsconfig/strictest": "2.0.2",
    "eslint": "8.56.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.2.0"
  }
}
