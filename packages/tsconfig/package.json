{
  "name": "tsconfig",
  "description": "custom tsconfig",
  "version": "1.0.0",
  "author": {
    "name": "Rintaro Itokawa",
    "email": "me@re-taro.dev",
    "url": "https://re-taro.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-taro/blog.re-taro.dev",
    "directory": "packages/tsconfig"
  },
  "scripts": {
    "lint": "run-s -c lint:*",
    "lint:eslint": "eslint . --ext .json,.cjs",
    "lint:prettier": "prettier --check '*.{json,cjs}'",
    "fmt": "run-s -c fmt:*",
    "fmt:eslint": "pnpm lint:eslint --fix",
    "fmt:prettier": "prettier --write '*.{json,cjs}'"
  },
  "devDependencies": {
    "@re-taro/eslint-config": "1.10.2",
    "@tsconfig/strictest": "2.0.2",
    "eslint": "8.48.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.0.3"
  }
}
