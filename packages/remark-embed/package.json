{
  "name": "remark-embed",
  "description": "remark plugin to embed external resources",
  "version": "1.0.0",
  "author": {
    "name": "Rintaro Itokawa",
    "email": "me@re-taro.dev",
    "url": "https://re-taro.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-taro/blog.re-taro.dev",
    "directory": "packages/remark-embed"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "analyze": "tsc -p tsconfig.packelyze.json && packelyze analyze-dts",
    "build": "pnpm run analyze && rollup -c",
    "lint": "run-s -c lint:*",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . -c",
    "lint:ts": "tsc -p . --noEmit",
    "fmt": "run-s -c fmt:*",
    "fmt:eslint": "pnpm lint:eslint --fix",
    "fmt:prettier": "prettier . -w",
    "test": "vitest --run"
  },
  "dependencies": {
    "mdast-utils": "workspace:*",
    "ts-array-length": "0.1.2",
    "unist-util-visit": "4.1.2"
  },
  "devDependencies": {
    "@re-taro/eslint-config": "2.1.1",
    "@rollup/plugin-replace": "5.0.5",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "11.1.5",
    "@types/mdast": "3.0.15",
    "@types/unist": "3.0.2",
    "endent": "2.1.0",
    "eslint": "8.55.0",
    "npm-run-all": "4.1.5",
    "packelyze": "0.2.0",
    "prettier": "3.1.1",
    "remark-gfm": "4.0.0",
    "remark-parse": "10.0.2",
    "remark-remove-position": "workspace:*",
    "rollup": "4.8.0",
    "tsconfig": "workspace:*",
    "unified": "10.1.2",
    "unist-builder": "4.0.0",
    "vitest": "1.0.4"
  }
}
